# --- Public Domains (Traffic from Cloudflare Tunnel) ---

n8n.damiankaplon.site {
    reverse_proxy n8n:5678
    tls /etc/ssl/caddy/origin.pem /etc/ssl/caddy/origin.key
}

damiankaplon.site {
# FIX: Point to the internal port (usually 80 for Nginx containers)
    reverse_proxy cv-react:80

    tls /etc/ssl/caddy/origin.pem /etc/ssl/caddy/origin.key
}

structify-auth.damiankaplon.site {
    reverse_proxy structify_keycloak:8080

    tls /etc/ssl/caddy/origin.pem /etc/ssl/caddy/origin.key
}


structify.damiankaplon.site {
    reverse_proxy structify_app:8080

    tls /etc/ssl/caddy/origin.pem /etc/ssl/caddy/origin.key
}

seafile.damiankaplon.site {
    tls {
            dns cloudflare {env.CLOUDFLARE_API_TOKEN}
        }
    reverse_proxy seafile:80 {
                                 header_up X-Forwarded-Proto {scheme}
                                 header_up Host {host}
                                 header_up X-Real-IP {remote}
                             }
}
